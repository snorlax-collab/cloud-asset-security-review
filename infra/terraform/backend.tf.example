# Copy to backend.tf and fill in before `terraform init -reconfigure`.
# Keeps state off local disk and out of shared folders/CI artifacts.
#
#   aws s3 mb s3://YOUR-TF-STATE-BUCKET --region ap-south-1
#   aws dynamodb create-table --table-name terraform-locks \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH \
#     --billing-mode PAY_PER_REQUEST --region ap-south-1

terraform {
  backend "s3" {
    bucket         = "YOUR-TF-STATE-BUCKET"
    key            = "asset-review/terraform.tfstate"
    region         = "ap-south-1"
    encrypt        = true
    dynamodb_table = "terraform-locks"
  }
}
