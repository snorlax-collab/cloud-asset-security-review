# Copy to .env (make setup does this for you). All values are optional.
# Without ANTHROPIC_API_KEY the LLM review falls back to a deterministic heuristic.

# Enables the real Claude-based security review (model: claude-opus-4-8).
ANTHROPIC_API_KEY=

# Slack alerting (optional). If set, findings at/above the threshold are posted
# to this Incoming Webhook. Create one at https://api.slack.com/messaging/webhooks
# Test it with:  asset-review notify-test
SLACK_WEBHOOK_URL=
SLACK_ALERT_THRESHOLD=LOW     # min severity to alert: INFO|LOW|MEDIUM|HIGH|CRITICAL
SLACK_MIN_CONFIDENCE=MEDIUM   # min confidence to alert: LOW|MEDIUM|HIGH (cuts false positives)
SLACK_NOTIFY_NEW_ASSETS=true  # post a blue informational card for every reviewed endpoint
# SLACK_DASHBOARD_URL=https://localhost:8000   # optional link on the summary line

# Production AWS mode — discovery Lambda → SQS → scanner workers → S3 + Slack.
# ASSET_QUEUE_URL=                         # set automatically in ECS/Lambda by Terraform
# REPORTS_S3_BUCKET=                       # workers upload JSON/MD; dashboard-sync builds index.html
# REPORTS_S3_PREFIX=reports                # optional key prefix inside the bucket
# AWS_REGION=ap-south-1
