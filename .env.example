# Copy to .env (make setup does this for you). All values are optional.
# Without ANTHROPIC_API_KEY the LLM review falls back to a deterministic heuristic.

# Enables the real Claude-based security review (model: claude-opus-4-8).
ANTHROPIC_API_KEY=

# Slack alerting (optional). If set, findings at/above the threshold are posted
# to this Incoming Webhook. Create one at https://api.slack.com/messaging/webhooks
# Test it with:  asset-review notify-test
SLACK_WEBHOOK_URL=
SLACK_ALERT_THRESHOLD=HIGH    # min severity to alert: INFO|LOW|MEDIUM|HIGH|CRITICAL
SLACK_MIN_CONFIDENCE=MEDIUM   # min confidence to alert: LOW|MEDIUM|HIGH (cuts false positives)

# Real AWS mode only — SQS queue the discovery Lambda publishes assets to.
# ASSET_QUEUE_URL=
# AWS_REGION=us-east-1
